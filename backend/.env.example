# SentiGuard Backend Environment Variables
# Copy this to .env and fill in your values

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# CORS (comma-separated allowed origins)
# In production, replace * with your frontend URL
ALLOWED_ORIGINS=*

# Model path (leave default unless you move the model)
MODEL_PATH=models/phishing_model.pkl
