{
  "manifest_version": 3,
  "name": "SentiGuard",
  "version": "1.0.0",
  "description": "Real-time phishing detection powered by AI. Protects you from malicious websites automatically.",
  "permissions": [
    "activeTab",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://sentiguard-api.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
