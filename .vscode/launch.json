{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🚀 Run SentiGuard API",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "${workspaceFolder}/backend",
      "console": "integratedTerminal",
      "envFile": "${workspaceFolder}/backend/.env"
    },
    {
      "name": "🧠 Train ML Model",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/ml_training/train.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
